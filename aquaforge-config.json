{
  "asset": {
    "type": "pool_configurator",
    "version": "2.3.1",
    "schema": "pbr_webgl_v3",
    "global_defaults": {
      "units": "imperial",
      "renderer": "three_webgl",
      "shadow_map": "PCFSoftShadowMap",
      "tone_mapping": "ACESFilmic",
      "exposure": 1.2
    },
    "pricing_engine": {
      "methods": {
        "LS": {
          "label": "Lump Sum (Base)",
          "description": "Fixed baseline configuration overhead cost"
        },
        "SF": {
          "label": "Square Footage",
          "description": "Computed horizontal or internal surface areas"
        },
        "LF": {
          "label": "Linear Feet",
          "description": "Boundary tracing — perimeter sweeps"
        },
        "PI": {
          "label": "Per Item Unit",
          "description": "Incremental scalar equipment additions"
        }
      }
    },
    "dimension_variables": {
      "pool_length": {
        "default": 40,
        "min": 10,
        "max": 100,
        "unit": "ft"
      },
      "pool_width": {
        "default": 20,
        "min": 8,
        "max": 50,
        "unit": "ft"
      },
      "pool_depth_avg": {
        "default": 5,
        "min": 3,
        "max": 12,
        "unit": "ft"
      }
    },
